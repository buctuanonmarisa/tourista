{
  "name": "tourista",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "deploy:check": "npm run lint && npm run typecheck && npm run build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:clips": "tsx prisma/seed-itinerary-clips.ts",
    "db:seed:tourme-clips": "tsx prisma/seed-tourme-area-short-clips.ts",
    "db:seed:tourme-real": "tsx prisma/seed-tourme-real-clips.ts",
    "db:repair:tourme": "tsx prisma/repair-tourme-data.ts",
    "db:cleanup:tourme": "tsx prisma/cleanup-and-reseed-tourme.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.15.0",
    "emoji-picker-react": "^4.19.1",
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "postcss": "^8",
    "prisma": "^5.15.0",
    "puppeteer": "^24.43.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.15.0",
    "typescript": "^5"
  }
}
